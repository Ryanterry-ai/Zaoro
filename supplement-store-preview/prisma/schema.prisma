datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Products {
  id String @id @default(uuid())
  name String?
  price Int?
  description String?
  image Int?
  stock String?
  sku String? @unique
  category DateTime?
  userId String?
  users Users? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Orders {
  id String @id @default(uuid())
  items String?
  total String?
  status DateTime?
  customerId String?
  shippingAddress String?
  createdAt DateTime
  userId String?
  users Users? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Categories {
  id String @id @default(uuid())
  name String?
  slug String?
  image Int?
  parent String?
  userId String?
  users Users? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Users {
  id String @id @default(uuid())
  email String @unique
  name String
  role String
  createdAt DateTime
  products Products[]
  orders Orders[]
  categories Categories[]

  @@index([email])
}
