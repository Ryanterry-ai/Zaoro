                    "verify:persistence":  "npx tsx scripts/verify-persistence.ts",
                    "verify:mcp":  "npx tsx scripts/test-mcp-pipeline.ts",
                    "verify:all":  "npm run verify:generation \u0026\u0026 npm run verify:multi-file \u0026\u0026 npm run verify:fullstack \u0026\u0026 npm run verify:telemetry \u0026\u0026 npm run verify:intelligence \u0026\u0026 npm run verify:synthesis \u0026\u0026 npm run verify:queue \u0026\u0026 npm run verify:persistence",
                    "test:unit":  "vitest run"
