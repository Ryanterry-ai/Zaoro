{
    "name": "build-same-engine",
    "version": "1.0.0",
    "private": true,
    "type": "module",
    "description": "Production-grade deterministic AST-first code synthesis and compiler engine",
    "main": "dist/index.js",
    "scripts": {
        "dev": "npx tsx src/test-harness.ts",
        "build": "tsc",
        "test": "npx tsx src/test-harness.ts",
        "start": "node dist/index.js",
        "server": "npx tsx src/server.ts",
        "verify:generation": "npx tsx scripts/verify-generation-layer.ts",
        "verify:multi-file": "npx tsx scripts/verify-multi-file.ts",
        "verify:fullstack": "npx tsx scripts/verify-fullstack-db.ts",
        "verify:telemetry": "npx tsx scripts/verify-telemetry.ts",
        "verify:intelligence": "npx tsx scripts/verify-business-intelligence.ts",
        "verify:synthesis": "npx tsx scripts/verify-business-synthesis.ts",
        "verify:queue": "npx tsx scripts/verify-build-queue.ts",
        "verify:persistence": "npx tsx scripts/verify-persistence.ts",
        "verify:mcp": "npx tsx scripts/test-mcp-pipeline.ts",
        "verify:all": "npm run verify:generation && npm run verify:multi-file && npm run verify:fullstack && npm run verify:telemetry && npm run verify:intelligence && npm run verify:synthesis && npm run verify:queue && npm run verify:persistence",
        "test:unit": "vitest run",
        "test:local": "npx tsx src/testing/local-test-runner.ts",
        "test:local:one": "npx tsx src/testing/local-test-runner.ts",
        "test:prompt": "npx tsx src/testing/local-test-runner.ts"
    },
    "dependencies": {
        "@anthropic-ai/sdk": "^0.110.0",
        "@babel/parser": "^7.24.0",
        "@prisma/client": "5.10.2",
        "@sentry/node": "^10.59.0",
        "@supabase/supabase-js": "^2.108.2",
        "@types/archiver": "^8.0.0",
        "archiver": "^8.0.0",
        "cheerio": "^1.2.0",
        "dotenv": "^17.4.2",
        "esbuild": "^0.28.1",
        "jsdom": "^29.1.1",
        "pixelmatch": "^7.2.0",
        "playwright": "^1.45.0",
        "pngjs": "^7.0.0",
        "posthog-node": "^5.38.2",
        "react": "^19.2.7",
        "react-dom": "^19.2.7",
        "recast": "^0.23.9",
        "simple-git": "^3.36.0",
        "tsx": "^4.22.4",
        "typescript": "^5.4.2",
        "zod": "^3.24.4"
    },
    "devDependencies": {
        "@types/jsdom": "^28.0.3",
        "@types/node": "^20.11.24",
        "@types/pngjs": "^6.0.5",
        "prisma": "5.10.2",
        "vitest": "^4.1.9"
    }
}
