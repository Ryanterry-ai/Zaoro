# Build Engine Environment Variables
# Copy this to .env and fill in your values

# Required: LLM API Keys
GROQ_API_KEY=
GEMINI_API_KEY=

# Optional: Database (Supabase PostgreSQL)
# If not set, engine uses file-based persistence
DATABASE_URL=

# Vercel Deployment
# Used by update-vercel-env.ps1 to auto-update ENGINE_URL after tunnel restart
VERCEL_TOKEN=

# Engine Configuration
ENGINE_PORT=3001
NODE_ENV=production
