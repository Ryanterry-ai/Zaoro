{
  "designSystem": {
    "name": "Commerce Design System",
    "version": "1.0.0",
    "colors": {
      "primitives": {
        "blue-50": "#EFF6FF",
        "blue-100": "#DBEAFE",
        "blue-200": "#BFDBFE",
        "blue-300": "#93C5FD",
        "blue-400": "#60A5FA",
        "blue-500": "#3B82F6",
        "blue-600": "#2563EB",
        "blue-700": "#1D4ED8",
        "blue-800": "#1E40AF",
        "blue-900": "#1E3A8A",
        "gray-50": "#F9FAFB",
        "gray-100": "#F3F4F6",
        "gray-200": "#E5E7EB",
        "gray-300": "#D1D5DB",
        "gray-400": "#9CA3AF",
        "gray-500": "#6B7280",
        "gray-600": "#4B5563",
        "gray-700": "#374151",
        "gray-800": "#1F2937",
        "gray-900": "#111827",
        "green-500": "#22C55E",
        "green-600": "#16A34A",
        "amber-500": "#F59E0B",
        "amber-600": "#D97706",
        "red-500": "#EF4444",
        "red-600": "#DC2626"
      },
      "semantic": {
        "primary": {
          "light": "{blue-600}",
          "dark": "{blue-400}",
          "contrast": "white"
        },
        "secondary": {
          "light": "{gray-600}",
          "dark": "{gray-400}",
          "contrast": "white"
        },
        "success": {
          "light": "{green-600}",
          "dark": "{green-500}",
          "contrast": "white"
        },
        "warning": {
          "light": "{amber-600}",
          "dark": "{amber-500}",
          "contrast": "white"
        },
        "error": {
          "light": "{red-600}",
          "dark": "{red-500}",
          "contrast": "white"
        },
        "background": {
          "primary": "{gray-50}",
          "secondary": "white",
          "tertiary": "{gray-100}"
        },
        "surface": {
          "primary": "white",
          "secondary": "{gray-50}",
          "elevated": "white"
        },
        "text": {
          "primary": "{gray-900}",
          "secondary": "{gray-600}",
          "tertiary": "{gray-500}",
          "inverse": "white",
          "link": "{blue-600}"
        },
        "border": {
          "light": "{gray-200}",
          "medium": "{gray-300}",
          "dark": "{gray-400}",
          "focus": "{blue-500}"
        }
      }
    },
    "spacing": {
      "scale": [0, 4, 8, 12, 16, 20, 24, 32, 40, 48, 64, 80, 96],
      "semantic": {
        "none": "0",
        "xs": "4px",
        "sm": "8px",
        "md": "16px",
        "lg": "24px",
        "xl": "32px",
        "2xl": "48px",
        "3xl": "64px",
        "4xl": "96px"
      }
    },
    "typography": {
      "fontFamilies": {
        "sans": "Inter, system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif",
        "mono": "JetBrains Mono, 'Fira Code', Consolas, monospace"
      },
      "fontWeights": {
        "normal": 400,
        "medium": 500,
        "semibold": 600,
        "bold": 700
      },
      "lineHeights": {
        "tight": 1.1,
        "snug": 1.375,
        "normal": 1.5,
        "relaxed": 1.625
      },
      "fontSizes": {
        "xs": "12px",
        "sm": "14px",
        "base": "16px",
        "lg": "18px",
        "xl": "20px",
        "2xl": "24px",
        "3xl": "30px",
        "4xl": "36px",
        "5xl": "48px",
        "6xl": "60px"
      },
      "headings": {
        "h1": { "fontSize": "48px", "fontWeight": 700, "lineHeight": 1.1 },
        "h2": { "fontSize": "36px", "fontWeight": 700, "lineHeight": 1.2 },
        "h3": { "fontSize": "24px", "fontWeight": 600, "lineHeight": 1.3 },
        "h4": { "fontSize": "20px", "fontWeight": 600, "lineHeight": 1.4 },
        "h5": { "fontSize": "18px", "fontWeight": 600, "lineHeight": 1.4 },
        "h6": { "fontSize": "16px", "fontWeight": 600, "lineHeight": 1.5 }
      }
    },
    "borderRadius": {
      "none": "0",
      "sm": "4px",
      "md": "8px",
      "lg": "12px",
      "xl": "16px",
      "2xl": "24px",
      "full": "9999px"
    },
    "shadows": {
      "none": "none",
      "xs": "0 1px 2px 0 rgba(0, 0, 0, 0.05)",
      "sm": "0 1px 3px 0 rgba(0, 0, 0, 0.1), 0 1px 2px -1px rgba(0, 0, 0, 0.1)",
      "md": "0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -2px rgba(0, 0, 0, 0.1)",
      "lg": "0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -4px rgba(0, 0, 0, 0.1)",
      "xl": "0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 8px 10px -6px rgba(0, 0, 0, 0.1)",
      "inner": "inset 0 2px 4px 0 rgba(0, 0, 0, 0.05)",
      "focus": "0 0 0 3px rgba(59, 130, 246, 0.4)"
    },
    "breakpoints": {
      "sm": "640px",
      "md": "768px",
      "lg": "1024px",
      "xl": "1280px",
      "2xl": "1536px"
    },
    "transitions": {
      "fast": "150ms ease",
      "normal": "200ms ease",
      "slow": "300ms ease"
    },
    "zIndices": {
      "hide": -1,
      "base": 0,
      "dropdown": 1000,
      "sticky": 1100,
      "modal": 1300,
      "popover": 1400,
      "toast": 1500,
      "tooltip": 1600
    }
  },
  "components": {
    "Button": {
      "variants": ["primary", "secondary", "outline", "ghost", "danger"],
      "sizes": ["sm", "md", "lg"],
      "states": ["default", "hover", "active", "disabled", "loading"]
    },
    "Input": {
      "variants": ["default", "error", "success"],
      "sizes": ["sm", "md", "lg"],
      "types": ["text", "email", "password", "number", "tel", "url", "search"]
    },
    "Select": {
      "variants": ["default", "error"],
      "sizes": ["sm", "md", "lg"]
    },
    "Card": {
      "variants": ["default", "outlined", "elevated"],
      "padding": ["none", "sm", "md", "lg"]
    },
    "Badge": {
      "variants": ["default", "success", "warning", "error", "info"],
      "sizes": ["sm", "md"]
    },
    "Table": {
      "variants": ["default", "striped", "bordered"],
      "sizes": ["sm", "md", "lg"]
    },
    "Modal": {
      "sizes": ["sm", "md", "lg", "xl", "full"],
      "variants": ["default", "confirmation", "form"]
    },
    "Dropdown": {
      "variants": ["default", "menu"],
      "positions": ["bottom", "top", "left", "right"]
    },
    "Tabs": {
      "variants": ["default", "pills", "underline"],
      "orientations": ["horizontal", "vertical"]
    },
    "Breadcrumb": {
      "variants": ["default", "compact"]
    },
    "Pagination": {
      "variants": ["default", "compact"],
      "sizes": ["sm", "md", "lg"]
    },
    "ProductCard": {
      "variants": ["default", "compact", "featured"],
      "aspectRatios": ["square", "portrait", "landscape"]
    },
    "ProductGallery": {
      "variants": ["default", "thumbnails", "zoom"],
      "aspectRatios": ["square", "portrait", "landscape"]
    },
    "VariantSelector": {
      "types": ["radio", "dropdown", "swatch", "button"],
      "layouts": ["horizontal", "vertical"]
    },
    "QuantitySelector": {
      "variants": ["default", "inline", "compact"]
    },
    "PriceDisplay": {
      "variants": ["default", "sale", "range"],
      "sizes": ["sm", "md", "lg"]
    },
    "Rating": {
      "variants": ["display", "interactive"],
      "sizes": ["sm", "md", "lg"],
      "maxRating": 5
    },
    "ProgressBar": {
      "variants": ["default", "circular", "stepped"],
      "sizes": ["sm", "md", "lg"]
    },
    "Toast": {
      "variants": ["default", "success", "error", "warning", "info"],
      "positions": ["top-right", "top-left", "bottom-right", "bottom-left", "top-center", "bottom-center"]
    },
    "Tooltip": {
      "positions": ["top", "bottom", "left", "right"],
      "variants": ["default", "rich"]
    },
    "Avatar": {
      "sizes": ["xs", "sm", "md", "lg", "xl"],
      "shapes": ["circle", "square"]
    },
    "Icon": {
      "sizes": ["xs", "sm", "md", "lg", "xl"],
      "library": "lucide-react"
    }
  },
  "patterns": {
    "pageLayout": {
      "maxWidth": "1280px",
      "padding": "{spacing.md}",
      "headerHeight": "64px",
      "footerHeight": "auto"
    },
    "formLayout": {
      "labelPosition": "top",
      "fieldSpacing": "{spacing.md}",
      "sectionSpacing": "{spacing.xl}",
      "maxWidth": "480px"
    },
    "grid": {
      "columns": 12,
      "gap": "{spacing.md}",
      "containerPadding": "{spacing.md}"
    },
    "cardGrid": {
      "mobile": 1,
      "tablet": 2,
      "desktop": 3,
      "wide": 4,
      "gap": "{spacing.md}"
    }
  },
  "accessibility": {
    "colorContrast": "WCAG 2.1 AA",
    "focusIndicators": "visible",
    "keyboardNavigation": "full",
    "screenReader": "supported",
    "reducedMotion": "respected",
    "highContrast": "supported"
  },
  "darkMode": {
    "enabled": true,
    "strategy": "class",
    "colors": {
      "background": {
        "primary": "{gray-900}",
        "secondary": "{gray-800}",
        "tertiary": "{gray-700}"
      },
      "surface": {
        "primary": "{gray-800}",
        "secondary": "{gray-700}",
        "elevated": "{gray-700}"
      },
      "text": {
        "primary": "{gray-50}",
        "secondary": "{gray-300}",
        "tertiary": "{gray-400}",
        "inverse": "{gray-900}",
        "link": "{blue-400}"
      },
      "border": {
        "light": "{gray-700}",
        "medium": "{gray-600}",
        "dark": "{gray-500}",
        "focus": "{blue-500}"
      }
    }
  }
}